rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isDirector() {
      return isAuthenticated() && userRole() == 'Director';
    }

    function isMTA() {
      return isAuthenticated() && userRole() == 'Manager - Technical Architect';
    }

    function isOpManager() {
      return isAuthenticated() && userRole() == 'Operation Manager';
    }

    // Director, MTA, or Op Manager — can manage tasks, change roles, etc.
    function isDirectorOrMTA() {
      return isDirector() || isMTA() || isOpManager();
    }

    // Director, MTA, or Operation Manager when treated as architect-level
    function isDirectorOrTechArchitect() {
      return isDirector() || isMTA() || isOpManager();
    }

    // Any of the three management/approver roles
    function isManager() {
      return isDirector() || isMTA() || isOpManager();
    }

    function isValidTaskCreate() {
      return request.resource.data.keys().hasAll([
        'title', 'description', 'assignedTo', 'assignedBy', 'reviewer',
        'dateAssigned', 'dueDate', 'status', 'submissions', 'createdAt', 'updatedAt',
        'taskType', 'taskLeadId', 'workerIds'
      ])
      && request.resource.data.dateAssigned is string
      && request.resource.data.dateAssigned.size() > 0
      && request.resource.data.dueDate is string
      && request.resource.data.dueDate.size() > 0
      && request.resource.data.taskType in ['delegated', 'non_delegated']
      && request.resource.data.workerIds is list;
    }

    function canReadTask(taskData) {
      return taskData.status != 'Deleted'
        || request.auth.uid == taskData.assignedTo
        || (taskData.keys().hasAny(['taskLeadId']) && request.auth.uid == taskData.taskLeadId)
        || (taskData.keys().hasAny(['workerIds']) && taskData.workerIds.hasAny([request.auth.uid]))
        || request.auth.uid == taskData.assignedBy
        || isDirectorOrTechArchitect();
    }

    function canHardDeleteDeletedTask(taskData) {
      return taskData.status == 'Deleted'
        && (
          request.auth.uid == taskData.assignedTo
          || request.auth.uid == taskData.assignedBy
        );
    }

    function isSoftDeleteUpdate() {
      return request.resource.data.status == 'Deleted' && resource.data.status != 'Deleted';
    }

    function isRestoreUpdate() {
      return request.resource.data.status != 'Deleted' && resource.data.status == 'Deleted';
    }

    function canSoftDeleteTask(taskData) {
      return request.auth.uid == taskData.assignedBy || isDirectorOrTechArchitect();
    }

    function canRestoreTask(taskData) {
      return canSoftDeleteTask(taskData);
    }

    // ── Users Collection ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read (needed for task dropdowns)
      allow read: if isAuthenticated();
      // Only Director or MTA can write (create via approval or change roles)
      allow create: if isDirectorOrMTA();
      allow update: if isDirectorOrMTA();
      allow delete: if isDirectorOrMTA();
    }

    // ── Signup Requests ──────────────────────────────────────────────────────
    match /signup_requests/{requestId} {
      // Registrant creates their own request
      allow create: if isAuthenticated() && request.auth.uid == requestId;
      // Registrant reads their own; managers read all
      allow read: if isAuthenticated() &&
        (request.auth.uid == requestId || isManager());
      // Only managers can approve/reject (update)
      allow update: if isManager();
      allow delete: if isDirectorOrMTA();
    }

    // ── Tasks Collection ─────────────────────────────────────────────────────
    match /tasks/{taskId} {
      // Deleted tasks are only visible to assigner or assignee
      allow read: if isAuthenticated() && canReadTask(resource.data);

      // Create: any authenticated user, with required date fields
      allow create: if isAuthenticated() && isValidTaskCreate();

      // Update rules
      allow update: if isAuthenticated() && (
        // Soft delete is restricted to assigner OR Director/MTA only.
        (isSoftDeleteUpdate() && canSoftDeleteTask(resource.data))
        // Restore from Deleted is restricted to users who can soft-delete.
        || (isRestoreUpdate() && canRestoreTask(resource.data))
        // For all other updates, preserve existing role-based permissions but
        // do not allow updates while task is in Deleted state.
        || (
          !isSoftDeleteUpdate() && !isRestoreUpdate() && resource.data.status != 'Deleted' && (
            isDirectorOrMTA()
            || request.auth.uid == resource.data.assignedTo
            || (resource.data.keys().hasAny(['taskLeadId']) && request.auth.uid == resource.data.taskLeadId)
            || (resource.data.keys().hasAny(['workerIds']) && resource.data.workerIds.hasAny([request.auth.uid]))
            || request.auth.uid == resource.data.reviewer
            || request.auth.uid == resource.data.assignedBy
          )
        )
      );

      // Permanent delete is allowed only for tasks already soft-deleted.
      allow delete: if isAuthenticated() && canHardDeleteDeletedTask(resource.data);
    }

    // ── Activity Logs (optional) ─────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isDirectorOrMTA();
    }
  }
}
